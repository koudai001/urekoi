{
  "name": "urekoi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "start": "pnpm -C apps/web start",
    "lint": "pnpm -C apps/web lint",
    "docs:lint": "redocly lint docs/openapi.yaml",
    "docs:build": "redocly build-docs docs/openapi.yaml -o docs/index.html",
    "docs:preview": "npx serve docs -l 4321",
    "db:reset": "apps/api/scripts/reset-db.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@redocly/cli": "^2.35.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
