{
  "name": "urekoi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "scripts": {
    "dev": "pnpm -C apps/web dev",
    "build": "pnpm -C apps/web build",
    "start": "pnpm -C apps/web start",
    "lint": "pnpm -C apps/web lint",
    "docs:lint": "redocly lint docs/openapi.yaml",
    "docs:build": "redocly build-docs docs/openapi.yaml -o docs/openapi.html",
    "docs:preview": "npx serve docs -l 4321",
    "docs:asyncapi:validate": "asyncapi validate docs/asyncapi.yaml",
    "docs:asyncapi:build": "asyncapi generate fromTemplate docs/asyncapi.yaml @asyncapi/html-template --param singleFile=true --output ./docs/.asyncapi-html --force-write --no-interactive && mv ./docs/.asyncapi-html/index.html ./docs/asyncapi.html && rm -rf ./docs/.asyncapi-html",
    "db:reset": "apps/api/scripts/reset-db.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@asyncapi/cli": "^6.0.2",
    "@asyncapi/generator": "^3.3.0",
    "@asyncapi/html-template": "^3.5.6",
    "@redocly/cli": "^2.35.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
